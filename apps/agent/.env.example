# Agent is configured via /etc/relay-agent/config.json by default.
# Individual fields can be overridden with these environment variables.

# Path to the JSON config file (default: /etc/relay-agent/config.json)
RELAY_CONFIG_PATH=/etc/relay-agent/config.json

# WebSocket URL of the Relay backend
RELAY_BACKEND_URL=wss://api.relay.parthsali.com/ws

# Device credentials — obtained from POST /devices/register
RELAY_DEVICE_ID=your-device-uuid
RELAY_DEVICE_SECRET=your-device-plain-secret

# Example config.json contents:
# {
#   "backend_url": "wss://api.relay.parthsali.com/ws",
#   "device_id":   "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
#   "device_secret": "64-char-hex-secret",
#   "brightness":  80,
#   "matrix_rows": 32,
#   "matrix_cols": 64
# }
